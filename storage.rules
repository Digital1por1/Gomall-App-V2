rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Tipografías propias: solo el dueño escribe en su carpeta (máx 10MB)
    match /fonts/{userId}/{allPaths=**} {
      allow read:  if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 10 * 1024 * 1024;
    }

    // Assets (logos, imágenes, recursos): lectura pública (para servirlos en las piezas),
    // pero cada usuario SOLO puede escribir en su propia carpeta assets/{uid}/… con límite de
    // tamaño y tipo (evita que suban archivos gigantes o usen tu Storage de hosting gratis).
    match /assets/{userId}/{allPaths=**} {
      allow read:  if true;
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 25 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*|video/.*');
    }
  }
}
