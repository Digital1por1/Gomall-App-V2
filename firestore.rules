rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Profiles: only the owner can read/write their profile
    match /profiles/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Admin can read all profiles
    match /profiles/{userId} {
      allow read: if request.auth != null && request.auth.token.email in ['digital@1por1.com.ar'];
      allow write: if request.auth != null && (
        request.auth.uid == userId ||
        request.auth.token.email in ['digital@1por1.com.ar']
      );
    }

    // Saved designs: only the owner
    match /usuarios/{userId}/disenos/{disenoId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Admin can read all designs
    match /usuarios/{userId}/disenos/{disenoId} {
      allow read: if request.auth != null && request.auth.token.email in ['digital@1por1.com.ar'];
    }

    // Usage history snapshots
    match /usuarios/{userId}/historial/{docId} {
      allow read, write: if request.auth != null && (
        request.auth.uid == userId ||
        request.auth.token.email in ['digital@1por1.com.ar']
      );
    }
  }
}
